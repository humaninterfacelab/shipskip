{
  "name": "@shipskip/cli",
  "version": "0.1.0",
  "description": "Bun CLI for running shipskip frontend tasks.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "shipskip": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "bun test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "build": "bun build src/index.ts --target bun --outfile dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/perplexity": "^3.0.31",
    "@ai-sdk/provider-utils": "^4.0.24",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.168",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "vscode-ripgrep": "^1.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "pino-pretty": "^13.1.3"
  }
}
